{
  "expo": {
    "name": "Pose Match",
    "slug": "pose-match",
    "scheme": "posematch",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.posematch.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.posematch.app"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Pose Match needs camera access to help you match poses.",
          "enableFrameProcessors": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe5af41a-03e3-4121-9577-ee76b6e745c1"
      }
    },
    "owner": "kvassa"
  }
}
