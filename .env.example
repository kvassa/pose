# Supabase (from Project Settings → API)
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase CLI only (https://supabase.com/dashboard/account/tokens)
# Used by `pnpm exec supabase link` — not needed for the mobile app
# SUPABASE_ACCESS_TOKEN=your-cli-access-token

# Pose worker (services/pose-worker + Railway) — shared with edge callback verifier
# CALLBACK_SECRET=your-random-secret
# POSE_WORKER_URL=https://your-app.up.railway.app

# Supabase edge function secrets (Dashboard → Edge Functions → Secrets, or `supabase secrets set`)
# POSE_WORKER_URL=https://your-app.up.railway.app
# POSE_WORKER_CALLBACK_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/pose-worker-callback
